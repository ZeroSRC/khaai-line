# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LINE LIFF
NEXT_PUBLIC_LIFF_ID=your-liff-id

# LINE Messaging API (for bot / server-side only)
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# J&T Express tracking — NOT wired in yet (see src/app/api/jt-track/route.ts). เว็บ tracking
# สาธารณะของ J&T มี slide-puzzle captcha ป้องกันบอท ไม่มี token คงที่ให้ใช้ ต้องรอ API key
# จาก J&T merchant program ก่อนถึงจะใช้ฟีเจอร์นี้ได้จริง
# JT_VERIFY_CODE=
# JT_VCK=

# ─────────────────────────────────────────────────────────
# DEV ONLY — รันบน localhost โดยไม่ต้องผ่าน LINE
# ─────────────────────────────────────────────────────────
# ใส่ 2 ตัวนี้แล้ว `npm run dev` จะข้าม LIFF login ทั้งหมด
# ใช้ LINE UID *ของจริง* ที่เป็นสมาชิกร้านอยู่แล้ว (ดูได้ที่ /settings/members)
# ไม่งั้นจะขึ้น "คุณไม่มีสิทธิ์เข้าถึงร้านนี้"
NEXT_PUBLIC_DEV_LINE_UID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_DEV_LINE_NAME=Dev User

# JWT Secret ตัวเดียวกับที่ตั้งเป็น JWT_SECRET ใน Edge Function verify-line
# Supabase Dashboard → Settings → API → JWT Secret
# ใช้เฉพาะ /api/dev-token ซึ่ง return 404 บน production
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
